GLASSOPS_AGENT_ID=change-me
# Backend's derived agent key (NOT the SECRET_KEY). On the dashboard host run:
#   docker compose exec glassops python -m app.secret_bootstrap agent
GLASSOPS_AGENT_KEY=change-me
# Use wss:// (TLS) for remote agents — plaintext ws:// exposes the agent key and
# all RPC traffic (shell/exec) to the network. ws:// is only safe for a loopback agent.
GLASSOPS_SERVER_URL=wss://dashboard.example.com/ws/agent
# For a self-signed / private CA, point this at the CA bundle (verification stays on):
# GLASSOPS_AGENT_CA=/etc/glassops/ca.pem
# Refuse to start if a remote connection would be plaintext:
# GLASSOPS_REQUIRE_AGENT_TLS=true
GLASSOPS_COLLECT_INTERVAL=1
GLASSOPS_ENABLE_DOCKER=true
GLASSOPS_ENABLE_GPU=false
# Host user for the web terminal. Unset means the terminal is refused unless you
# opt into a host login prompt below (which allows logging in as any host account).
# GLASSOPS_TERMINAL_USER=ubuntu
# GLASSOPS_ALLOW_LOGIN_PROMPT=false
