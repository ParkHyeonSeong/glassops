# GlassOps Configuration
GLASSOPS_PORT=7440
# REQUIRED in production. Generate a strong one: openssl rand -hex 32
# Leave empty to auto-generate & persist one at <data>/secret.key on first run.
# Weak/placeholder values (e.g. "change-me") are REJECTED at startup.
GLASSOPS_SECRET_KEY=
GLASSOPS_ADMIN_EMAIL=admin@glassops.local
# GLASSOPS_ADMIN_PASSWORD=     # If unset, random password is generated and printed to logs on first run
GLASSOPS_DB_PATH=/app/data/glassops.db

# Agent
GLASSOPS_AGENT_ID=local
# GLASSOPS_AGENT_KEY is auto-derived from SECRET_KEY for the built-in agent (do not set here).
# For REMOTE agents, set it to the backend's derived agent key:
#   docker compose exec glassops python -m app.secret_bootstrap agent
GLASSOPS_COLLECT_INTERVAL=1
GLASSOPS_ENABLE_GPU=false
GLASSOPS_ENABLE_DOCKER=true

# Terminal — host user for shell access (empty = login prompt)
# GLASSOPS_TERMINAL_USER=ubuntu

# IP whitelist (comma-separated, empty = allow all)
# GLASSOPS_ALLOWED_IPS=192.168.1.0/24,10.0.0.5
