# GlassOps Configuration
GLASSOPS_PORT=7440
# REQUIRED in production. Generate a strong one: openssl rand -hex 32
# Leave empty to auto-generate & persist one at <data>/secret.key on first run.
# Weak/placeholder values (e.g. "change-me") are REJECTED at startup.
GLASSOPS_SECRET_KEY=
GLASSOPS_ADMIN_EMAIL=admin@glassops.local
# GLASSOPS_ADMIN_PASSWORD=     # If unset, a random one-time password is written to <data>/initial_admin_password (0600); forced change on first login
GLASSOPS_DB_PATH=/app/data/glassops.db

# Agent
GLASSOPS_AGENT_ID=local
# GLASSOPS_AGENT_KEY is auto-derived from SECRET_KEY for the built-in agent (do not set here).
# For REMOTE agents, set it to the backend's derived agent key:
#   docker compose exec glassops python -m app.secret_bootstrap agent
GLASSOPS_COLLECT_INTERVAL=1
GLASSOPS_ENABLE_GPU=false
GLASSOPS_ENABLE_DOCKER=true

# Terminal — host user for shell access (empty = login prompt)
# GLASSOPS_TERMINAL_USER=ubuntu

# IP whitelist (comma-separated, empty = allow all)
# GLASSOPS_ALLOWED_IPS=192.168.1.0/24,10.0.0.5

# Reverse proxies whose X-Real-IP / X-Forwarded-Proto headers are trusted (CIDR list).
# Default is the bundled nginx (loopback). Add your upstream LB/proxy IP if you run one.
# GLASSOPS_TRUSTED_PROXIES=127.0.0.1,::1
# Force the Secure flag on auth cookies (set when TLS is terminated by an upstream proxy).
# GLASSOPS_FORCE_SECURE_COOKIES=false
# Browser origins allowed on WebSockets (CSWSH guard). Comma-separated hostnames/URLs,
# e.g. https://ops.lan,http://10.0.0.9:7440. Empty = allow same-host access (match request Host).
# GLASSOPS_ALLOWED_ORIGINS=
# Restrict which SMTP relay hosts the alert config may use (comma-separated hostnames/IPs).
# Empty = any host that passes SSRF checks (loopback/link-local/metadata blocked, RFC1918 allowed).
# GLASSOPS_SMTP_ALLOWED_HOSTS=
