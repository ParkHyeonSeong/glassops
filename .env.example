# Backend
GLASSOPS_BACKEND_HOST=0.0.0.0
GLASSOPS_BACKEND_PORT=8000
GLASSOPS_SECRET_KEY=your-secret-key-here
GLASSOPS_DB_PATH=./data/glassops.db

# Frontend (Vite dev server)
VITE_BACKEND_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_PORT=3000

# Agent
GLASSOPS_AGENT_ID=agent-01
GLASSOPS_AGENT_KEY=your-agent-api-key
GLASSOPS_SERVER_URL=ws://localhost:8000/ws/agent
GLASSOPS_COLLECT_INTERVAL=1
GLASSOPS_ENABLE_GPU=true
GLASSOPS_ENABLE_DOCKER=true
GLASSOPS_ENABLE_NETWORK=false
