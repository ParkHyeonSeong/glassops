# GlassOps Configuration
GLASSOPS_PORT=7440
# REQUIRED in production. Generate a strong one: openssl rand -hex 32
# Leave empty to auto-generate & persist one at <data>/secret.key on first run.
# Weak/placeholder values (e.g. "change-me") are REJECTED at startup.
GLASSOPS_SECRET_KEY=
GLASSOPS_ADMIN_EMAIL=admin@glassops.local
# GLASSOPS_ADMIN_PASSWORD=     # If unset, a random one-time password is written to <data>/initial_admin_password (0600); forced change on first login
GLASSOPS_DB_PATH=/app/data/glassops.db

# Agent
GLASSOPS_AGENT_ID=local
# GLASSOPS_AGENT_KEY is auto-derived from SECRET_KEY for the built-in agent (do not set here).
# For REMOTE agents, set it to the backend's derived agent key:
#   docker compose exec glassops python -m app.secret_bootstrap agent
GLASSOPS_COLLECT_INTERVAL=1
GLASSOPS_ENABLE_GPU=false
GLASSOPS_ENABLE_DOCKER=true

# Terminal — host user for shell access. Unset + no per-user host mapping means the
# terminal is refused unless you opt into a host login prompt (below).
# GLASSOPS_TERMINAL_USER=ubuntu
# Allow a host `login` prompt when no terminal user is configured. This lets a
# dashboard admin authenticate as ANY host account (incl. root) — off by default.
# Set true to keep the legacy login-prompt behavior.
# GLASSOPS_ALLOW_LOGIN_PROMPT=false

# IP whitelist (comma-separated, empty = allow all)
# GLASSOPS_ALLOWED_IPS=192.168.1.0/24,10.0.0.5

# Reverse proxies whose forwarded headers are trusted (CIDR list). Drives BOTH the
# backend (X-Real-IP / X-Forwarded-Proto) AND nginx real_ip (X-Forwarded-For), so the
# IP whitelist + per-IP rate limits/lockouts see the true client behind an upstream
# LB/TLS proxy. Loopback (the bundled nginx) is always trusted; add your proxy CIDR(s).
# GLASSOPS_TRUSTED_PROXIES=10.0.0.0/24
# Force the Secure flag on auth cookies (set when TLS is terminated by an upstream proxy).
# GLASSOPS_FORCE_SECURE_COOKIES=false
# Browser origins trusted for the WebSocket CSWSH guard AND the HTTP CSRF check on
# state-changing requests (POST/PUT/DELETE/PATCH). Comma-separated hostnames/URLs,
# e.g. https://ops.lan,http://10.0.0.9:7440. Empty = allow same-host access (the Origin
# hostname must match the request Host). Distinct from GLASSOPS_CORS_ORIGINS (the CORS
# response-header allowlist), which only affects cross-origin XHR/fetch.
# GLASSOPS_ALLOWED_ORIGINS=
# Origins echoed in CORS response headers for a split frontend/backend deployment
# (comma-separated). Default http://localhost:3000,http://localhost:3300. Not needed when
# the SPA is same-origin behind the bundled nginx. "*" entries are ignored.
# GLASSOPS_CORS_ORIGINS=
# Restrict which SMTP relay hosts the alert config may use (comma-separated hostnames/IPs).
# Empty = any host that passes SSRF checks (loopback/link-local/metadata blocked, RFC1918 allowed).
# GLASSOPS_SMTP_ALLOWED_HOSTS=

# Network connection audit (metadata only; admin-only, audit-logged). Off by default.
# GLASSOPS_ENABLE_NET_AUDIT=false
# GLASSOPS_NET_AUDIT_MAX_EVENTS=200
# GLASSOPS_NET_AUDIT_TOP_TALKERS=20
# GLASSOPS_NET_AUDIT_EVENT_DAYS=7
# GLASSOPS_NET_AUDIT_ROLLUP_DAYS=30
